local function performKnifeAttack()
    local myChar = player.Character
    if not myChar then return end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    
    local targets = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local theirHRP = p.Character:FindFirstChild("HumanoidRootPart")
            local theirHumanoid = p.Character:FindFirstChild("Humanoid")
            if theirHRP and theirHumanoid and theirHumanoid.Health > 0 then
                local dist = (theirHRP.Position - myHRP.Position).Magnitude
                if dist <= KNIFE_RANGE then
                    table.insert(targets, {Player = p, Humanoid = theirHumanoid, Distance = dist, Name = p.Name})
                end
            end
        end
    end
    
    table.sort(targets, function(a, b) return a.Distance < b.Distance end)
    
    if #targets == 0 then
        TweenService:Create(actionButtonFrame, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, true), {BackgroundColor3 = Color3.fromRGB(50, 50, 0)}):Play()
        task.wait(0.1)
        TweenService:Create(actionButtonFrame, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = Color3.fromRGB(0, 0, 0)}):Play()
        showNotification("Нет целей в радиусе!", "⚠")
        return
    end
    
    TweenService:Create(actionButtonFrame, TweenInfo.new(0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, true), {Size = UDim2.new(0, 65, 0, 65)}):Play()
    task.wait(0.05)
    TweenService:Create(actionButtonFrame, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 75, 0, 75)}):Play()
    
    local killedCount = 0
    for _, target in ipairs(targets) do
        if target.Humanoid and target.Humanoid.Health > 0 then
            target.Humanoid.Health = 0
            killedCount = killedCount + 1
        end
        local knife = myChar:FindFirstChild("Knife") or (player.Backpack and player.Backpack:FindFirstChild("Knife"))
        if knife then
            local attackRemote = knife:FindFirstChild("RemoteEvent") or knife:FindFirstChild("Stab") or knife:FindFirstChild("Attack")
            if attackRemote then pcall(function() attackRemote:FireServer(target.Player.Character) end) end
        end
    end
    
    if killedCount > 0 then notifyKnifeKill(killedCount) end
    
    TweenService:Create(actionButtonFrame, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = Color3.fromRGB(0, 100, 0)}):Play()
    task.wait(0.15)
    TweenService:Create(actionButtonFrame, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundColor3 = Color3.fromRGB(0, 0, 0)}):Play()
end

local function performShoot()
    local char = player.Character; if not char then return end
    local gun = char:FindFirstChild("Gun") or (player.Backpack and player.Backpack:FindFirstChild("Gun"))
    if not gun then showNotification("Нет оружия!", "⚠"); return end
    
    local targetPart = nil; local targetName = "неизвестный"
    
    if AimbotFOV.Enabled then 
        local head = getTargetInFOV()
        if head then targetPart = head; local tp = Players:GetPlayerFromCharacter(head.Parent); if tp then targetName = tp.Name end end
    end
    
    if not targetPart and Aimbot.SilentAim then 
        local murderer = getMurderer()
        if murderer then targetPart = murderer; local tp = Players:GetPlayerFromCharacter(murderer.Parent); if tp then targetName = tp.Name end end
    end
    
    if not targetPart then showNotification("Убийца не найден!", "⚠"); return end
    
    if gun.Parent == player.Backpack then char.Humanoid:EquipTool(gun); task.wait(0.08) end
    
    local shootRemote = gun:FindFirstChild("Normal") or gun:FindFirstChild("Shoot") or gun:FindFirstChildOfClass("RemoteEvent")
    if shootRemote and shootRemote:IsA("RemoteEvent") then 
        shootRemote:FireServer(targetPart.Position)
        notifyShootKill(targetName)
    else 
        gun:Activate()
        notifyShootKill(targetName)
    end
    
    TweenService:Create(actionButtonFrame, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, true), {Size = UDim2.new(0, 65, 0, 65)}):Play()
    task.wait(0.08)
    TweenService:Create(actionButtonFrame, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 75, 0, 75)}):Play()
end

