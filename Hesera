local activeNotifications = {}

local function showNotification(text, symbol, duration)
    if #activeNotifications > 4 then
        local old = table.remove(activeNotifications, 1)
        if old and old.Parent then old:Destroy() end
    end
    
    local notif = Instance.new("Frame", NotificationGui)
    notif.Size = UDim2.new(0, 240, 0, 35)
    notif.Position = UDim2.new(1, 10, 0.80, -#activeNotifications * 40)
    notif.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    notif.BackgroundTransparency = 0.1
    notif.BorderSizePixel = 0
    notif.ZIndex = 99999
    notif.ClipsDescendants = true
    Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 8)
    
    local leftBar = Instance.new("Frame", notif)
    leftBar.Size = UDim2.new(0, 3, 1, 0)
    leftBar.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    leftBar.BorderSizePixel = 0
    leftBar.ZIndex = 99999
    
    local symbolLabel = Instance.new("TextLabel", notif)
    symbolLabel.Size = UDim2.new(0, 25, 1, 0)
    symbolLabel.Position = UDim2.new(0, 8, 0, 0)
    symbolLabel.BackgroundTransparency = 1
    symbolLabel.Text = symbol or "●"
    symbolLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    symbolLabel.Font = Enum.Font.GothamBold
    symbolLabel.TextSize = 14
    symbolLabel.ZIndex = 99999
    
    local label = Instance.new("TextLabel", notif)
    label.Size = UDim2.new(1, -40, 1, 0)
    label.Position = UDim2.new(0, 35, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 9
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 99999
    
    table.insert(activeNotifications, notif)
    
    notif.Position = UDim2.new(1, 250, notif.Position.Y.Scale, notif.Position.Y.Offset)
    TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(1, -250, notif.Position.Y.Scale, notif.Position.Y.Offset)}):Play()
    
    task.delay(duration or 3, function()
        if notif and notif.Parent then
            local index = table.find(activeNotifications, notif)
            if index then table.remove(activeNotifications, index) end
            TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(1, 250, notif.Position.Y.Scale, notif.Position.Y.Offset)}):Play()
            task.wait(0.3)
            notif:Destroy()
        end
    end)
end

