local oldNamecall = nil
local function hookFire()
    if oldNamecall then return end
    local mt = getrawmetatable(game); local old = mt.__namecall; oldNamecall = old; setreadonly(mt, false)
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod(); local args = {...}
        if (method == "FireServer" or method == "InvokeServer") and #args > 0 and typeof(args[1]) == "Vector3" then
            if AimbotFOV.Enabled then 
                local target = getTargetInFOV()
                if target then return old(self, target.Position) end 
            end
            if Aimbot.SilentAim and silentAimActive then 
                local murderer = getMurderer()
                if murderer then return old(self, murderer.Position) end 
            end
        end
        return old(self, ...)
    end); setreadonly(mt, true)
end

local function unhookFire()
    if oldNamecall then local mt = getrawmetatable(game); setreadonly(mt, false); mt.__namecall = oldNamecall; setreadonly(mt, true); oldNamecall = nil end
end

