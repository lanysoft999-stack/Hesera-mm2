    if not myHRP then showNotification("Нет HumanoidRootPart!", "⚠"); return end
    
    local myRole = getMyRole()
    local killedCount = 0
    local totalTargets = 0
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local theirHumanoid = p.Character:FindFirstChild("Humanoid")
            if theirHumanoid and theirHumanoid.Health > 0 then totalTargets = totalTargets + 1 end
        end
    end
    
    if totalTargets == 0 then showNotification("Нет целей для убийства!", "⚠"); return end
    
    local originalPos = myHRP.CFrame
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local theirHRP = p.Character:FindFirstChild("HumanoidRootPart")
            local theirHumanoid = p.Character:FindFirstChild("Humanoid")
            if theirHRP and theirHumanoid and theirHumanoid.Health > 0 then
                local tpPos = theirHRP.CFrame + (theirHRP.CFrame.LookVector * 3) + Vector3.new(0, 2, 0)
                
                if myRole == "Murderer" then
                    myHRP.CFrame = tpPos
                    task.wait(0.03)
                    local knife = myChar:FindFirstChild("Knife") or (player.Backpack and player.Backpack:FindFirstChild("Knife"))
                    if knife then
                        local attackRemote = knife:FindFirstChild("RemoteEvent") or knife:FindFirstChild("Stab") or knife:FindFirstChild("Attack")
                        if attackRemote then pcall(function() attackRemote:FireServer(p.Character) end) end
                    end
                    theirHumanoid.Health = 0
                    killedCount = killedCount + 1
                    task.wait(0.05)
                elseif hasWeapon() then
                    myHRP.CFrame = tpPos
                    task.wait(0.03)
                    local gun = myChar:FindFirstChild("Gun") or (player.Backpack and player.Backpack:FindFirstChild("Gun"))
                    if gun then
                        local shootRemote = gun:FindFirstChild("Normal") or gun:FindFirstChild("Shoot") or gun:FindFirstChildOfClass("RemoteEvent")
                        if shootRemote and shootRemote:IsA("RemoteEvent") then pcall(function() shootRemote:FireServer(theirHRP.Position) end) end
                    end
                    theirHumanoid.Health = 0
                    killedCount = killedCount + 1
                    task.wait(0.05)
                end
            end
        end
    end
    
    if myHRP and myHRP.Parent then myHRP.CFrame = originalPos end
    
    if killedCount > 0 then notifyKillAll(killedCount)
    else showNotification("Не удалось убить (нужен нож или оружие)!", "⚠") end
end

