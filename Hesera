RunService.RenderStepped:Connect(function(dt)
    updateESP()
    updateChams()
    updateCrosshairUI()
    antiDetection()
    
    if MenuColor == "Rainbow" then
        updateMenuColors()
    end
    
    if Aimbot.FireButtonEnabled and (Aimbot.SilentAim or AimbotFOV.Enabled) then
        updateActionButtonVisibility()
        if actionButtonFrame and actionButtonFrame.Visible then
            local knifeIcon = actionIcon:FindFirstChild("KnifeIcon")
            if knifeIcon then
                knifeIcon.Rotation = (knifeIcon.Rotation + 120 * dt) % 360
            end
        end
    end
    
    -- FOV Circle rendering
    if AimbotFOV.Enabled and fovCircle then
        fovCircle.Visible = true
        local stroke = fovCircle:FindFirstChildOfClass("UIStroke")
        if not stroke then return end
        
        if AimbotFOV.Mode == "WeaponOnly" and not hasWeapon() then
            stroke.Color = Color3.fromRGB(255, 255, 255); stroke.Transparency = 0.4
        else
            local target = getTargetInFOV()
            if target then
                -- FOV наводит камеру на цель
                local targetPos = target.Position; local camPos = camera.CFrame.Position
                local lookAt = CFrame.lookAt(camPos, targetPos)
                camera.CFrame = CFrame.new(camPos.X, camPos.Y, camPos.Z) * lookAt.Rotation
                
                pcall(function()
                    local char = player.Character
                    if char then
                        local hrp = char:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local lookDir = (targetPos - hrp.Position).Unit
                            lookDir = Vector3.new(lookDir.X, 0, lookDir.Z)
                            if lookDir.Magnitude > 0 then
                                hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, math.atan2(lookDir.X, lookDir.Z), 0)
                            end
                        end
                    end
                end)
                
                stroke.Color = Color3.fromRGB(0, 255, 100); stroke.Transparency = 0.2
            else
                stroke.Color = Color3.fromRGB(255, 255, 255); stroke.Transparency = 0.4
            end
        end
    elseif fovCircle then
        fovCircle.Visible = false
    end
end)

