local function getAllSettings()
    return {
        ESP = ESP, Visual = Visual, VisualEffects = VisualEffects,
        MainExtras = MainExtras, CrosshairSettings = CrosshairSettings,
        FogSettings = FogSettings, SkySettings = SkySettings,
        AimbotFOV = AimbotFOV, Aimbot = Aimbot,
        MovementSettings = MovementSettings, FOV = FOV,
        FOV_Enabled = FOV_Enabled, FPSBoost = FPSBoost,
        GunGrabEnabled = GunGrabEnabled, KNIFE_RANGE = KNIFE_RANGE,
        MenuColor = MenuColor
    }
end

local function applySettings(data)
    if not data then return end
    if data.MenuColor then MenuColor = data.MenuColor; updateMenuColors() end
    if data.ESP then for k,v in pairs(data.ESP) do ESP[k] = v end end
    if data.Visual then 
        for k,v in pairs(data.Visual) do Visual[k] = v end 
        applyGraphicsMode()
        if Visual.Fog and FogSettings.Enabled then
            updateFogColor()
            Lighting.FogEnd = FogSettings.Distance
            Lighting.FogStart = FogSettings.Distance * 0.3
        end
        if Visual.BlackSky then setSkyColor("Black") end
    end
    if data.VisualEffects then 
        for k,v in pairs(data.VisualEffects) do VisualEffects[k] = v end
        if player.Character then applyEffects(player.Character) end
    end
    if data.MainExtras then 
        for k,v in pairs(data.MainExtras) do MainExtras[k] = v end
        if lockButtonFrame then lockButtonFrame.Visible = MainExtras.ShiftLock end
        if MainExtras.ShiftLock then enableShiftLock() else disableShiftLock() end
        if MainExtras.BunnyHop then toggleBunnyHop(true) end
        if MainExtras.Spinbot then toggleSpinbot(true) end
        if Rage.Fly then setFly(true) end
        if Rage.Noclip then toggleNoclip(true) end
        if MainExtras.ClickTP then toggleClickTP(true) end
        if MainExtras.RemoveUI then toggleRemoveUI(true) end
    end
    if data.CrosshairSettings then for k,v in pairs(data.CrosshairSettings) do CrosshairSettings[k] = v end; updateCrosshairUI() end
    if data.FogSettings then 
        for k,v in pairs(data.FogSettings) do FogSettings[k] = v end
        if FogSettings.Enabled then updateFogColor(); Lighting.FogEnd = FogSettings.Distance; Lighting.FogStart = FogSettings.Distance * 0.3 end
    end
    if data.SkySettings then for k,v in pairs(data.SkySettings) do SkySettings[k] = v end; if SkySettings.Enabled then setSkyColor(SkySettings.Color) end end
    if data.AimbotFOV then 
        for k,v in pairs(data.AimbotFOV) do AimbotFOV[k] = v end
        updateFOVSize(); 
        if fovCircle then fovCircle.Visible = AimbotFOV.Enabled end
        if AimbotFOV.Enabled then hookFire() end
    end
    if data.Aimbot then 
        for k,v in pairs(data.Aimbot) do Aimbot[k] = v end
        updateActionButtonVisibility()
        if Aimbot.SilentAim then hookFire() end
    end
    if data.MovementSettings then for k,v in pairs(data.MovementSettings) do MovementSettings[k] = v end end
    if data.FOV then FOV = data.FOV end
    if data.FOV_Enabled ~= nil then FOV_Enabled = data.FOV_Enabled; camera.FieldOfView = data.FOV_Enabled and FOV or 70 end
    if data.FPSBoost ~= nil then FPSBoost = data.FPSBoost; Lighting.GlobalShadows = not data.FPSBoost; Lighting.Brightness = data.FPSBoost and 1 or 2 end
    if data.GunGrabEnabled ~= nil then GunGrabEnabled = data.GunGrabEnabled; if gunBtn then gunBtn.Visible = data.GunGrabEnabled end end
    if data.KNIFE_RANGE ~= nil then KNIFE_RANGE = data.KNIFE_RANGE end
end

local function saveConfig()
    local data = getAllSettings()
    local json = HttpService:JSONEncode(data)
    writefile("HESERACFG_Config.json", json)
    _G.HeseracfgConfig = data
    notifySaved()
end

local function loadConfig()
    local success, result = pcall(function()
        if isfile("HESERACFG_Config.json") then return readfile("HESERACFG_Config.json") end
    end)
    if success and result and result ~= "" then
        local success2, data = pcall(function() return HttpService:JSONDecode(result) end)
        if success2 and data then applySettings(data); notifyLoaded() end
    end
end

local function copyConfig()
    local data = getAllSettings(); local json = HttpService:JSONEncode(data)
    setclipboard(json); notifyCopied()
end

local function pasteConfig()
    local clip = getclipboard()
    if clip and clip ~= "" then
        local success, data = pcall(function() return HttpService:JSONDecode(clip) end)
        if success and data then applySettings(data); notifyPasted() end
    end
end

